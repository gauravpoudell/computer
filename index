<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nepal NewsHub - HTML Syllabus Project</title>

<!-- External CSS (simulated) -->
<link rel="stylesheet" href="style.css">

<!-- Embedded CSS -->
<style>
body{
  font-family: Arial;
  margin:0;
  background:#f5f5f5;
}
header{
  background:#111;
  color:white;
  padding:15px;
  text-align:center;
}
nav a{
  color:white;
  margin:10px;
  text-decoration:none;
}
section{
  padding:20px;
  background:white;
  margin:10px;
  border-radius:10px;
}
.table{
  width:100%;
  border-collapse:collapse;
}
.table th, .table td{
  border:1px solid #333;
  padding:8px;
}
footer{
  background:#111;
  color:white;
  text-align:center;
  padding:15px;
}
</style>
</head>

<body>

<header>
  <h1>Nepal NewsHub</h1>
  <h2><i>HTML Learning Project</i></h2>
  <nav>
    <a href="#home">Home</a>
    <a href="#news">News</a>
    <a href="#form">Form</a>
    <a href="#contact">Contact</a>
  </nav>
</header>

<section id="home">
  <h2>Welcome</h2>
  <p>This website demonstrates <b>HTML syllabus topics</b> including <i>tables, forms, lists, and multimedia</i>.</p>
  <p>Water formula: H<sub>2</sub>O | Einstein: E = mc<sup>2</sup></p>
  <mark>Important: This is a student project</mark>
</section>

<section id="news">
  <h2>Latest News (Ordered List)</h2>
  <ol type="1">
    <li>Nepal tourism increases</li>
    <li>Tech startups rising in Kathmandu</li>
    <li>Sports events gaining popularity</li>
  </ol>

  <h3>Categories (Unordered List)</h3>
  <ul type="square">
    <li>Sports</li>
    <li>Technology</li>
    <li>World</li>
  </ul>

  <h3>Definition List</h3>
  <dl>
    <dt>HTML</dt>
    <dd>Markup language for web pages</dd>
    <dt>CSS</dt>
    <dd>Styles web pages</dd>
  </dl>
</section>

<section>
  <h2>News Table</h2>
  <table class="table">
    <tr>
      <th>Category</th>
      <th>Headline</th>
    </tr>
    <tr>
      <td>Sports</td>
      <td>Nepal wins football match</td>
    </tr>
    <tr>
      <td>Tech</td>
      <td>New AI app launched</td>
    </tr>
  </table>
</section>

<section id="form">
  <h2>Subscribe Form</h2>
  <form>
    Name: <input type="text"><br><br>
    Email: <input type="email"><br><br>

    Gender:<br>
    <input type="radio" name="g"> Male
    <input type="radio" name="g"> Female<br><br>

    Interests:<br>
    <input type="checkbox"> Sports
    <input type="checkbox"> Tech<br><br>

    Message:<br>
    <textarea></textarea><br><br>

    <button type="submit">Submit</button>
  </form>
</section>

<section>
  <h2>Multimedia (HTML5)</h2>

  <h3>Audio</h3>
  <audio controls>
    <source src="audio.mp3" type="audio/mp3">
  </audio>

  <h3>Video</h3>
  <video width="300" controls>
    <source src="video.mp4" type="video/mp4">
  </video>

  <h3>Canvas</h3>
  <canvas id="myCanvas" width="200" height="100" style="border:1px solid black;"></canvas>

  <h3>SVG</h3>
  <svg width="100" height="100">
    <circle cx="50" cy="50" r="40" stroke="black" fill="red"/>
  </svg>
</section>

<section id="contact">
  <h2>Contact</h2>
  <address>
    Nepal NewsHub<br>
    Lamachaur, Pokhara<br>
    Nepal
  </address>

  <p><a href="https://www.google.com">External Link Example</a></p>
  <p><a href="#home">Back to Top</a></p>
</section>

<footer>
  <p>© 2026 Nepal NewsHub</p>
</footer>

<!-- Inline CSS example -->
<p style="text-align:center;color:gray;">Inline CSS Example Text</p>

</body>
</html>
